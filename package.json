{
  "name": "clarity",
  "version": "1.0.0",
  "description": "File Organizer Desktop Application",
  "main": "dist-electron/main.js",
  "author": "Antigravity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cvzxeov/CLARITY.git"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run build:electron && wait-on tcp:5173 && electron .\"",
    "build": "tsc && vite build && npm run build:electron && electron-builder",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').copyFileSync('src/img/logo_app.png', 'dist-electron/logo_app.png')\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.4.5",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^25.3.1",
    "electron-builder": "^24.6.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.clarity.app",
    "productName": "Clarity",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/img/logo_app.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "setup.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cvzxeov",
        "repo": "CLARITY"
      }
    ]
  }
}
